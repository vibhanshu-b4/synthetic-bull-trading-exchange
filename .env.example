# REST API base URL (no trailing slash)
VITE_API_BASE_URL=https://opensoft-backend.duckdns.org

# WebSocket base URL — used as the Vite dev-proxy target
VITE_WS_BASE_URL=ws://opensoft-backend.duckdns.org:8001

# Enable built-in mock data for static deployments (no backend required)
VITE_USE_MOCKS=true
